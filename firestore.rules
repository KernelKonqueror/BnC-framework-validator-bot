rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    function isValidAttempt(data, uid) {
      return data.keys().hasAll(['userId', 'caseText', 'framework', 'missingBucket', 'grade', 'feedback', 'createdAt']) &&
        data.keys().size() == 7 &&
        data.userId == uid &&
        data.caseText is string && data.caseText.size() <= 10000 &&
        data.framework is string && data.framework.size() <= 10000 &&
        data.missingBucket is string && data.missingBucket.size() <= 10000 &&
        data.grade is string && data.grade in ['S', 'A', 'B', 'C'] &&
        data.feedback is string && data.feedback.size() <= 10000 &&
        data.createdAt is timestamp;
    }

    match /users/{userId}/attempts/{attemptId} {
      allow read, list: if isOwner(userId) && resource.data.userId == userId;
      allow create: if isOwner(userId) && isValidId(attemptId) && isValidAttempt(incoming(), userId);
      allow delete, update: if false;
    }
  }
}
